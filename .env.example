# Kimera Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# Loaded automatically by kimera via python-dotenv

# --- Anthropic Claude (required for `kimera generate`) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Dynatrace MCP (optional, for `kimera generate --use-dt-mcp`) ---
# Your Dynatrace SaaS environment URL (*.apps.dynatrace.com)
DT_ENVIRONMENT=https://your-tenant.apps.dynatrace.com

# Platform token created at: https://<tenant>.apps.dynatrace.com/ui/access-tokens
# Required scopes (7 minimum):
#   - mcp-gateway:servers:invoke   (invoke tools on hosted MCP gateway)
#   - mcp-gateway:servers:read     (read MCP server metadata)
#   - app-engine:apps:run          (required for execute_dql tool)
#   - storage:buckets:read         (base DQL data access)
#   - storage:smartscape:read      (Smartscape topology queries)
#   - storage:security.events:read (KSPM compliance findings)
#   - storage:events:read          (general event data access)
#   - davis-copilot:nl2dql:execute (optional, for natural language to DQL generation)
#   - davis-copilot:conversations:execute (optional, for Davis CoPilot conversations)
DT_PLATFORM_TOKEN=dt0c01....

# K8s cluster name in Dynatrace (for KSPM queries)
# Find at: Dynatrace > Kubernetes > your cluster > name
CLUSTER_NAME=your-cluster-name
